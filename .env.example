# ── OpenCAD server configuration ──────────────────────────────────────────
# Copy this file to .env and fill in your values for local development.
# In production (Cloud Run), set these as environment variables in the
# service configuration — never commit secrets to git.

# Server
PORT=3000

# PostgreSQL — Cloud SQL in production
DATABASE_URL=postgres://opencad:opencad@localhost:5432/opencad

# Storage backend: "local" or "gcs"
STORAGE_BACKEND=local
STORAGE_PATH=./data/files

# Set to your GCS bucket name when STORAGE_BACKEND=gcs
# GCS_BUCKET=opencad-files-prod

# Auth — set AUTH_ENABLED=true in production
AUTH_ENABLED=false
FIREBASE_PROJECT_ID=your-firebase-project-id

# Legacy JWT secret (used for internal signing; keep strong in production)
JWT_SECRET=dev-secret-change-in-production

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:1420,https://opencad.archi

# Logging
RUST_LOG=opencad_server=debug,tower_http=info
