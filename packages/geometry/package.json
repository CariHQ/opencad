{
  "name": "@opencad/geometry",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts"
    },
    "./wasm": {
      "types": "./dist/wasm/opencad_geometry.d.ts",
      "import": "./dist/wasm/opencad_geometry.js"
    }
  },
  "scripts": {
    "build": "pnpm build:ts && pnpm build:wasm",
    "build:ts": "tsc --project tsconfig.json",
    "build:wasm": "cargo build --manifest-path Cargo.toml --release --target wasm32-unknown-unknown && wasm-bindgen --target web --out-dir dist/wasm target/wasm32-unknown-unknown/release/opencad_geometry.wasm",
    "build:wasm:dev": "cargo build --manifest-path Cargo.toml --target wasm32-unknown-unknown && wasm-bindgen --target web --out-dir dist/wasm target/wasm32-unknown-unknown/debug/opencad_geometry.wasm",
    "test:rust": "cargo test --manifest-path Cargo.toml",
    "dev": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage target"
  },
  "dependencies": {
    "@opencad/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "fast-check": "^4.7.0",
    "typescript": "^6.0.2",
    "vitest": "^1.4.0"
  }
}
