{
  "$schema": "https://schema.tauri.app/config/2/capability.json",
  "identifier": "default",
  "description": "Default capability set for OpenCAD Desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "fs:allow-read-home",
    "fs:allow-write-home",
    "fs:allow-read-appdata",
    "fs:allow-write-appdata",
    "fs:allow-exists"
  ]
}
