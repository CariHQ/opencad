{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for OpenCAD Desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:default",
    "fs:default",
    "fs:read-all",
    "fs:write-all",
    "fs:scope-home-recursive",
    "fs:scope-appdata-recursive",
    "fs:scope-applocaldata-recursive"
  ]
}
