{
  "name": "@opencad/app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@opencad/shared": "workspace:*",
    "@opencad/document": "workspace:*",
    "@opencad/geometry": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0",
    "react-router-dom": "^7.0.0",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.2.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.4.0",
    "vite": "^6.0.0",
    "vitest": "^1.4.0"
  }
}
