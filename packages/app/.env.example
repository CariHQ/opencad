# ── OpenCAD React app — environment variables ─────────────────────────────
# Copy this to .env.local for local development.
# For production, set these as build-time env vars in your CI/CD pipeline.
# VITE_ prefix is required for Vite to expose variables to the browser.

# Firebase web app config
# https://console.firebase.google.com → Project settings → Your apps → Web app
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# API base URL (the Rust server)
VITE_API_URL=http://localhost:3000
