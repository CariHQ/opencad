{
  "name": "@opencad/sync-rs",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pkg": {
      "types": "./pkg/opencad_sync.d.ts",
      "import": "./pkg/opencad_sync.js"
    }
  },
  "scripts": {
    "build:rust": "wasm-pack build --target web --out-dir pkg",
    "build:ts": "tsc",
    "build": "pnpm run build:rust && pnpm run build:ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:rust": "cargo test --manifest-path Cargo.toml"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^4.1.5",
    "@testing-library/jest-dom": "^6.0.0"
  }
}
