{
  "name": "opencad",
  "version": "0.0.1",
  "private": true,
  "description": "Browser-native, AI-powered, open-source BIM platform",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/CariHQ/opencad.git"
  },
  "homepage": "https://opencad.archi",
  "bugs": {
    "url": "https://github.com/CariHQ/opencad/issues"
  },
  "packageManager": "pnpm@9.0.0",
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "dev:browser": "turbo run dev --filter=@opencad/app",
    "dev:desktop": "turbo run dev --filter=@opencad/desktop",
    "build": "turbo run build",
    "build:browser": "turbo run build --filter=@opencad/app",
    "build:desktop": "turbo run build --filter=@opencad/desktop",
    "test": "turbo run test --filter=!@opencad/e2e",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "turbo run test:coverage --filter=!@opencad/e2e",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "husky": "^9.1.7",
    "lefthook": "^2.1.5",
    "lightningcss": "^1.32.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManagerArgs": [
    "--strict-peer-dependencies"
  ],
  "dependencies": {
    "lucide-react": "^1.8.0"
  }
}
