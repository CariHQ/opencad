{
  "name": "opencad",
  "version": "1.1.0",
  "private": true,
  "description": "Browser-native, AI-powered, open-source BIM platform",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/CariHQ/opencad.git"
  },
  "homepage": "https://opencad.archi",
  "bugs": {
    "url": "https://github.com/CariHQ/opencad/issues"
  },
  "packageManager": "pnpm@9.0.0",
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --filter=@opencad/desktop",
    "dev:browser": "turbo run dev --filter=@opencad/app",
    "dev:desktop": "turbo run dev --filter=@opencad/desktop",
    "dev:server": "bash -c 'PORT=$(grep -E \"^PORT=\" server/.env 2>/dev/null | cut -d= -f2 || echo 47821); PIDS=$(lsof -ti:$PORT 2>/dev/null); if [ -n \"$PIDS\" ]; then echo \"Port $PORT busy (pid $PIDS) — killing\"; kill -9 $PIDS; sleep 0.5; fi; cd server && cargo run'",
    "build": "turbo run build",
    "build:browser": "turbo run build --filter=@opencad/app",
    "build:desktop": "turbo run build --filter=@opencad/desktop",
    "sign:macos": "bash scripts/sign-macos.sh",
    "test": "turbo run test --filter=!@opencad/e2e",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "turbo run test:coverage --filter=!@opencad/e2e",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "ci:local": "turbo run typecheck lint && turbo run test:unit --filter='!@opencad/desktop'",
    "prepare": "husky"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.0.0",
    "@semantic-release/npm": "^12.0.0",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "semantic-release": "^24.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.1.7",
    "lefthook": "^2.1.5",
    "lightningcss": "^1.32.0",
    "prettier": "^3.8.3",
    "turbo": "^2.0.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManagerArgs": [
    "--strict-peer-dependencies"
  ],
  "dependencies": {
    "lucide-react": "^1.8.0"
  }
}
