# Copy to .env for local development
DATABASE_URL=postgres://opencad:opencad@localhost:5434/opencad

# local | gcs
STORAGE_BACKEND=local
STORAGE_PATH=./data/files

# GCS (only needed when STORAGE_BACKEND=gcs)
# GCS_BUCKET=opencad-files-prod

PORT=47821

# Set to true and provide JWT_SECRET when deploying
AUTH_ENABLED=false
JWT_SECRET=change-me-in-production

# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:1420
